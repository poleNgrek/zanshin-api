{
  "name": "zanshin-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx remix dev --port 3000",
    "build": "bunx remix build",
    "start": "bunx remix-serve ./build/index.js",
    "typecheck": "bunx tsc --noEmit",
    "lint:plugin": "npm --prefix ./eslint-plugin-zanshin install --no-fund --no-audit && npm --prefix ./eslint-plugin-zanshin run build",
    "prelint": "bun run lint:plugin",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "depcheck:circular": "bunx madge --circular --extensions ts,tsx --ts-config ./tsconfig.json ./app/src",
    "test:unit": "bun test ./tests/api-client.test.ts ./tests/schemas.test.ts ./tests/token-store.test.ts",
    "test": "bun run test:unit && bun run depcheck:circular",
    "check-imports": "bun ./scripts/organize_imports.ts check",
    "organize-imports": "bun ./scripts/organize_imports.ts write",
    "test:e2e": "bunx playwright test",
    "test:e2e:api": "PLAYWRIGHT_REAL_API=1 API_BASE_URL=http://127.0.0.1:4000 bunx playwright test tests/e2e/real-api.spec.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-pigment-css": "^9.0.0",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "isbot": "^5.1.39",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@remix-run/dev": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "bun-types": "^1.3.13",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "madge": "^8.0.0",
    "storybook": "8.6.14",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3"
  }
}
