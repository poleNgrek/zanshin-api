{
  "include": ["remix.env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["eslint-plugin-zanshin/**"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "types": ["node", "bun-types"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "~/*": ["app/*"],
      "@zanshin/api": ["app/src/api/index.ts"],
      "@zanshin/components": ["app/src/components/index.ts"],
      "@zanshin/fixtures": ["app/src/__fixtures__/index.ts"],
      "@zanshin/providers": ["app/src/providers/index.ts"],
      "@zanshin/schemas": ["app/src/schemas/index.ts"],
      "@zanshin/types": ["app/src/types/index.ts"],
      "@zanshin/utils": ["app/src/utils/index.ts"],
      "@zanshin/*": ["app/src/*"]
    }
  }
}
